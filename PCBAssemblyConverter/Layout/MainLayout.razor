@using PCBAssemblyConverter.Localization
@using PCBAssemblyConverter.Presentation.Enum

@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject LocalizationService LocalizationService

<HeadContent>
    <RadzenTheme Theme="material" />
</HeadContent>

<RadzenLayout>
    <RadzenHeader>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid gx-xxl-5">
                <a class="navbar-brand p-0" href="@this.NavigationManager.BaseUri">PCB Assembly Converter</a>
                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav ms-auto me-lg-2">
                        <li class="nav-item py-1">
                            <RadzenDropDown @bind-Value="this.LocalizationService.Language" Data="@EnumOptions.Languages.Options.Localize(this.LocalizationService)" TValue="Language" TextProperty="@(nameof(EnumOption<>.DisplayText))" ValueProperty="@(nameof(EnumOption<>.Value))" />
                        </li>
                        <li class="nav-item py-1">
                            <div class="vr d-none d-lg-flex h-100 mx-lg-2"></div>
                        </li>
                        <li class="nav-item py-1">
                            <div class="h-100 align-content-center">
                                <a href="https://github.com/koktoh/PCBAssemblyConverter" target="_blank">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-github" viewBox="0 0 16 16">
                                        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
                                    </svg>
                                </a>
                            </div>
                        </li>
                        <li class="nav-item py-1">
                            <div class="vr d-none d-lg-flex h-100 mx-lg-2"></div>
                        </li>
                        <li class="nav-item py-1">
                            <div class="h-100 align-content-center">
                                <label class="align-middle">v@(this.Version)</label>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </RadzenHeader>
    <RadzenBody class="px-0">
        <div class="container-xxl g-xxl-5">
            <RadzenStack Orientation="Orientation.Vertical">
                @Body
            </RadzenStack>
        </div>
    </RadzenBody>
</RadzenLayout>
<RadzenComponents />

@code {
    private string Version { get; set; } = "0.0.0";

    protected override void OnInitialized()
    {
        base.OnInitialized();

        var assembly = System.Reflection.Assembly.GetExecutingAssembly();
        var version = assembly.GetName().Version;

        if (version is not null)
        {
            this.Version = $"{version.Major}.{version.Minor}.{version.Build}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        var language = await this.JSRuntime.InvokeAsync<string>("getBrowserLanguage");

        if (language.StartsWith("ja"))
        {
            this.LocalizationService.Language = Language.Japanese;
        }
        else
        {
            this.LocalizationService.Language = Language.English;
        }
    }
}